{
  "name": "spfx-local-workbench",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "publisher": "BeauCameron",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bcameron1231/SPFx-LocalWorkbench"
  },
  "engines": {
    "vscode": "^1.100.0",
    "node": "22.x"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "SPFx",
    "SharePoint",
    "SharePoint Framework",
    "Web Parts",
    "Workbench",
    "Local Development"
  ],
  "activationEvents": [
    "workspaceContains:**/config/package-solution.json",
    "onWebviewPanel:spfxLocalWorkbench"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "icons": {
      "fluentui-testbeaker": {
        "description": "%icons.fluentui-testbeaker.description%",
        "default": {
          "fontPath": "media/icons.woff",
          "fontCharacter": "\\F3A5"
        }
      },
      "fluentui-localelanguage": {
        "description": "%icons.fluentui-localelanguage.description%",
        "default": {
          "fontPath": "media/icons.woff",
          "fontCharacter": "\\F2B7"
        }
      },
      "fluentui-sync": {
        "description": "%icons.fluentui-sync.description%",
        "default": {
          "fontPath": "media/icons.woff",
          "fontCharacter": "\\E895"
        }
      },
      "fluentui-developertools": {
        "description": "%icons.fluentui-developertools.description%",
        "default": {
          "fontPath": "media/icons.woff",
          "fontCharacter": "\\EC7A"
        }
      }
    },
    "commands": [
      {
        "command": "spfx-local-workbench.openWorkbench",
        "title": "%command.spfx-local-workbench.openWorkbench.title%",
        "category": "SPFx Local Workbench",
        "icon": "$(fluentui-testbeaker)"
      },
      {
        "command": "spfx-local-workbench.startServe",
        "title": "%command.spfx-local-workbench.startServe.title%",
        "category": "SPFx Local Workbench",
        "icon": "$(play)"
      },
      {
        "command": "spfx-local-workbench.detectWebParts",
        "title": "%command.spfx-local-workbench.detectWebParts.title%",
        "category": "SPFx Local Workbench",
        "icon": "$(fluentui-sync)"
      },
      {
        "command": "spfx-local-workbench.scaffoldMockConfig",
        "title": "%command.spfx-local-workbench.scaffoldMockConfig.title%",
        "category": "SPFx Local Workbench",
        "icon": {
          "light": "media/sync-light.svg",
          "dark": "media/sync-dark.svg"
        }
      },
      {
        "command": "spfx-local-workbench.openDevTools",
        "title": "%command.spfx-local-workbench.openDevTools.title%",
        "category": "SPFx Local Workbench",
        "icon": "$(fluentui-developertools)"
      },
      {
        "command": "spfx-local-workbench.mockDataMenu",
        "title": "%command.spfx-local-workbench.mockDataMenu.title%",
        "category": "SPFx Local Workbench",
        "icon": "$(database)"
      },
      {
        "command": "spfx-local-workbench.generateStatusStubs",
        "title": "%command.spfx-local-workbench.generateStatusStubs.title%",
        "category": "SPFx Mock Data"
      },
      {
        "command": "spfx-local-workbench.importJsonMock",
        "title": "%command.spfx-local-workbench.importJsonMock.title%",
        "category": "SPFx Mock Data"
      },
      {
        "command": "spfx-local-workbench.importCsvMock",
        "title": "%command.spfx-local-workbench.importCsvMock.title%",
        "category": "SPFx Mock Data"
      },
      {
        "command": "spfx-local-workbench.recordRequests",
        "title": "%command.spfx-local-workbench.recordRequests.title%",
        "category": "SPFx Mock Data"
      }
    ],
    "submenus": [
      {
        "id": "spfx-local-workbench.mockData",
        "label": "%submenu.spfx-local-workbench.mockData.label%",
        "icon": "$(database)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "spfx-local-workbench.openWorkbench",
          "when": "resourceFilename =~ /\\.manifest\\.json$/",
          "group": "navigation"
        },
        {
          "command": "spfx-local-workbench.detectWebParts",
          "when": "spfxLocalWorkbench.isWorkbench",
          "group": "navigation"
        },
        {
          "command": "spfx-local-workbench.openDevTools",
          "when": "spfxLocalWorkbench.isWorkbench",
          "group": "navigation"
        },
        {
          "command": "spfx-local-workbench.mockDataMenu",
          "when": "spfxLocalWorkbench.isWorkbench",
          "group": "navigation"
        }
      ],
      "webview/title": [
        {
          "command": "spfx-local-workbench.detectWebParts",
          "when": "webviewType == spfxLocalWorkbench",
          "group": "navigation"
        },
        {
          "command": "spfx-local-workbench.openDevTools",
          "when": "webviewType == spfxLocalWorkbench",
          "group": "navigation"
        },
        {
          "command": "spfx-local-workbench.mockDataMenu",
          "when": "webviewType == spfxLocalWorkbench",
          "group": "navigation"
        }
      ],
      "spfx-local-workbench.mockData": [
        {
          "command": "spfx-local-workbench.scaffoldMockConfig",
          "group": "1_scaffold"
        },
        {
          "command": "spfx-local-workbench.generateStatusStubs",
          "group": "2_generate"
        },
        {
          "command": "spfx-local-workbench.importJsonMock",
          "group": "3_import"
        },
        {
          "command": "spfx-local-workbench.importCsvMock",
          "group": "3_import"
        },
        {
          "command": "spfx-local-workbench.recordRequests",
          "group": "4_record"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.spfxLocalWorkbench.title%",
      "properties": {
        "spfxLocalWorkbench.serveUrl": {
          "type": "string",
          "default": "https://localhost:4321",
          "description": "%configuration.spfxLocalWorkbench.serveUrl.description%"
        },
        "spfxLocalWorkbench.autoOpenWorkbench": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.spfxLocalWorkbench.autoOpenWorkbench.description%"
        },
        "spfxLocalWorkbench.context.siteUrl": {
          "type": "string",
          "default": "https://contoso.sharepoint.com/sites/devsite",
          "description": "%configuration.spfxLocalWorkbench.context.siteUrl.description%"
        },
        "spfxLocalWorkbench.context.webUrl": {
          "type": "string",
          "default": "https://contoso.sharepoint.com/sites/devsite",
          "description": "%configuration.spfxLocalWorkbench.context.webUrl.description%"
        },
        "spfxLocalWorkbench.context.userDisplayName": {
          "type": "string",
          "default": "Local Workbench User",
          "description": "%configuration.spfxLocalWorkbench.context.userDisplayName.description%"
        },
        "spfxLocalWorkbench.context.userEmail": {
          "type": "string",
          "default": "user@contoso.onmicrosoft.com",
          "description": "%configuration.spfxLocalWorkbench.context.userEmail.description%"
        },
        "spfxLocalWorkbench.context.userLoginName": {
          "type": "string",
          "default": "i:0#.f|membership|user@contoso.onmicrosoft.com",
          "description": "%configuration.spfxLocalWorkbench.context.userLoginName.description%"
        },
        "spfxLocalWorkbench.context.culture": {
          "type": "string",
          "default": "en-US",
          "description": "%configuration.spfxLocalWorkbench.context.culture.description%"
        },
        "spfxLocalWorkbench.context.isAnonymousGuestUser": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.spfxLocalWorkbench.context.isAnonymousGuestUser.description%"
        },
        "spfxLocalWorkbench.context.customContext": {
          "type": "object",
          "default": {},
          "description": "%configuration.spfxLocalWorkbench.context.customContext.description%",
          "additionalProperties": true
        },
        "spfxLocalWorkbench.theme.preset": {
          "type": "string",
          "default": "teamSite",
          "enum": [
            "teamSite",
            "communicationSite",
            "dark",
            "highContrast",
            "custom"
          ],
          "enumDescriptions": [
            "%configuration.spfxLocalWorkbench.theme.preset.enumDescriptions.teamSite%",
            "%configuration.spfxLocalWorkbench.theme.preset.enumDescriptions.communicationSite%",
            "%configuration.spfxLocalWorkbench.theme.preset.enumDescriptions.dark%",
            "%configuration.spfxLocalWorkbench.theme.preset.enumDescriptions.highContrast%",
            "%configuration.spfxLocalWorkbench.theme.preset.enumDescriptions.custom%"
          ],
          "description": "%configuration.spfxLocalWorkbench.theme.preset.description%"
        },
        "spfxLocalWorkbench.theme.customColors": {
          "type": "object",
          "default": {},
          "description": "%configuration.spfxLocalWorkbench.theme.customColors.description%",
          "additionalProperties": {
            "type": "string"
          }
        },
        "spfxLocalWorkbench.pageContext.webTitle": {
          "type": "string",
          "default": "Local Workbench",
          "description": "%configuration.spfxLocalWorkbench.pageContext.webTitle.description%"
        },
        "spfxLocalWorkbench.pageContext.webDescription": {
          "type": "string",
          "default": "Local development workbench for SPFx web parts",
          "description": "%configuration.spfxLocalWorkbench.pageContext.webDescription.description%"
        },
        "spfxLocalWorkbench.pageContext.webTemplate": {
          "type": "string",
          "default": "STS#3",
          "description": "%configuration.spfxLocalWorkbench.pageContext.webTemplate.description%"
        },
        "spfxLocalWorkbench.pageContext.isNoScriptEnabled": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.spfxLocalWorkbench.pageContext.isNoScriptEnabled.description%"
        },
        "spfxLocalWorkbench.pageContext.isSPO": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.spfxLocalWorkbench.pageContext.isSPO.description%"
        },
        "spfxLocalWorkbench.proxy.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.spfxLocalWorkbench.proxy.enabled.description%"
        },
        "spfxLocalWorkbench.proxy.mockFile": {
          "type": "string",
          "default": ".spfx-workbench/api-mocks.json",
          "description": "%configuration.spfxLocalWorkbench.proxy.mockFile.description%"
        },
        "spfxLocalWorkbench.proxy.defaultDelay": {
          "type": "number",
          "default": 0,
          "description": "%configuration.spfxLocalWorkbench.proxy.defaultDelay.description%"
        },
        "spfxLocalWorkbench.proxy.fallbackStatus": {
          "type": "number",
          "default": 404,
          "description": "%configuration.spfxLocalWorkbench.proxy.fallbackStatus.description%"
        },
        "spfxLocalWorkbench.proxy.logRequests": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.spfxLocalWorkbench.proxy.logRequests.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && npm run generate:css-types && npm-run-all compile:*",
    "compile:extension": "node esbuild.js",
    "compile:webview": "node webview/esbuild.config.js",
    "generate:css-types": "tcm webview/src",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:webview": "node webview/esbuild.config.js --watch",
    "watch:css-types": "tcm webview/src --watch",
    "package": "npm run check-types && npm run lint && npm-run-all package:*",
    "package:extension": "node esbuild.js --production",
    "package:webview": "node webview/esbuild.config.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "generate:icons": "node scripts/generateIcons.js",
    "i18n:extract": "npx vscode-nls-dev extract -i src -o i18n -l package.nls.json || echo 'Install vscode-nls-dev to run extraction'",
    "i18n:generate": "npx vscode-nls-dev create-package -s package.nls.json -d i18n -o i18n-packages || echo 'Install vscode-nls-dev to run generation'",
    "i18n:help": "echo 'Use npx vscode-nls-dev extract/create-package or install vscode-nls-dev as a devDependency'"
  },

  "dependencies": {
    "vscode-nls": "^5.0.0"
  },
  "devDependencies": {
    "@fluentui/react": "^8.110.10",
    "@types/node": "22.x",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "subset-font": "^1.4.10",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
